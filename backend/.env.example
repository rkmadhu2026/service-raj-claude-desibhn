# Copy to .env in backend/ (do not commit secrets)
NEXEARN_APP_ENV=development
NEXEARN_DEBUG=0
NEXEARN_LOG_LEVEL=info
# Comma-separated (browser apps only). Empty = CORS off (same origin).
# NEXEARN_CORS_ORIGINS=https://app.example.com,http://localhost:3000
# Path to the static site (repo root with NexEarn Platform.html)
# NEXEARN_SITE_ROOT=/var/www/santhira
# Behind a path-prefixing reverse proxy
# NEXEARN_ROOT_PATH=/nexearn
#
# SQLAlchemy async URL. Default: SQLite file backend/.dev.db
# NEXEARN_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/nexearn
# JWT (HS256) — set a long random string in all non-local envs
# NEXEARN_JWT_SECRET=replace-with-64-chars-random-hex
# NEXEARN_ACCESS_TOKEN_EXPIRE_MINUTES=15
# NEXEARN_REFRESH_TOKEN_EXPIRE_DAYS=30
# Optional: Redis for JWT access jti denylist (logout / stolen-token check). e.g. redis://localhost:6379/0
# NEXEARN_REDIS_URL=
# Optional host allow list (e.g. behind LB)
# NEXEARN_ALLOWED_HOSTS=app.example.com
